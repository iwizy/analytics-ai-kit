# =========================
# QDRANT
# =========================
QDRANT_COLLECTION=analytics_context

# =========================
# MODELS
# =========================
EMBEDDING_MODEL=nomic-embed-text
DRAFT_MODEL=qwen3-coder:14b
REVIEW_MODEL=qwen2.5:7b
REFINE_MODEL=qwen3-coder:14b
PIPELINE_DRAFT_MODEL=qwen3-coder:14b
PIPELINE_GAP_MODEL=qwen2.5:7b
PIPELINE_REFINE_MODEL=qwen3-coder:14b

# =========================
# CHUNKING
# =========================
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# =========================
# SEARCH / CONTEXT
# =========================
SEARCH_LIMIT=8
CONTEXT_PACK_LIMIT=12
PIPELINE_SECTION_WORKERS=4
PIPELINE_STAGE_TIMEOUT_SEC=240
PIPELINE_MAX_RETRIES=1
